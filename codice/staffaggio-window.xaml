<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Staffaggio"
    Width="320"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    FontFamily="Segoe UI">
    <!-- Il guscio della finestra: un titolo, un contenitore vuoto (righe)
         che lo script riempie una riga per cavo, e il pulsante Verifica.
         Vedi Capitolo "In pyRevit" del libro. -->
    <StackPanel Margin="16">
        <TextBlock Text="Cavi nella passerella"
                   FontWeight="Bold"
                   FontSize="13"
                   Margin="0,0,0,12"/>
        <!-- lo script aggiunge qui una riga (nome + casella) per ogni cavo -->
        <StackPanel x:Name="righe"/>
        <Button x:Name="verifica"
                Content="Verifica"
                Height="30"
                Margin="0,14,0,0"
                Click="verifica_click"/>
    </StackPanel>
</Window>

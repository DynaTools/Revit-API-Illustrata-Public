<Window
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Quante staffe?" Height="120" Width="260"
  WindowStartupLocation="CenterScreen">
  <StackPanel Margin="12">
    <TextBlock Text="Interasse di progetto (m):"/>
    <TextBox x:Name="valore" Text="1.5" Margin="0,6,0,0"/>
    <Button Content="OK" Click="ok_click" Margin="0,10,0,0"/>
  </StackPanel>
</Window>
